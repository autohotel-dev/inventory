# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (REQUERIDO para crear usuarios desde el servidor)
# Encuéntralo en: Supabase Dashboard > Settings > API > service_role key
# ⚠️ NUNCA expongas esta clave en el cliente
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional: For development
DATABASE_URL=your_database_url_here

# Google OAuth (if using)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Site Configuration
# Para desarrollo local: http://localhost:3000
# Para producción: https://inventory-luxor.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Web Push Notifications (Guest Notification System)
# Generate VAPID keys: npx web-push generate-vapid-keys
# Then paste them here:
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your_email@hotel.com

# Cron Job Secret (for secure cron endpoints)
CRON_SECRET=your_random_secret_here

# Local Print Server (for thermal printer via USB)
# Development: http://localhost:3001
# Production: http://[IP_DE_PC_CON_IMPRESORA]:3001
NEXT_PUBLIC_PRINT_SERVER_URL=http://localhost:3001
